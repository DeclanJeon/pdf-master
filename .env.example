# PDF마스터 환경설정
# ===========================================

# API / app URLs
# VITE_API_URL is read at frontend build time.
# Local dev: leave empty so Vite proxy handles same-origin /api requests, or use http://localhost:3001 / http://127.0.0.1:3001 only.
# Production: set only when the API is hosted on a separate origin; omit/leave empty for same-origin /api.
VITE_API_URL=
PORT=3001
NODE_ENV=development  # production으로 변경 시 서버가 자동으로 DOMAIN 기반 URL 사용
DOMAIN=your-domain.com  # 운영 도메인 (NODE_ENV=production일 때 모든 URL 자동 파생)
# PUBLIC_BASE_URL, APP_URL, FRONTEND_URL, CORS_ORIGIN, GOOGLE_REDIRECT_URI,
# POLAR_CHECKOUT_SUCCESS_URL, POLAR_CHECKOUT_CANCEL_URL 는 NODE_ENV + DOMAIN에서 자동 파생됨
# 명시적으로 설정하면 자동 파생을 덮어씁니다.

# Google OAuth (WORK-01)
# Google Cloud Console에서 Web application OAuth client를 생성한 뒤 입력하세요.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/callback  # PUBLIC_BASE_URL + /api/auth/callback 에서 자동 파생 (명시 설정 가능)
# 운영에서는 32바이트 이상 랜덤 문자열을 사용하세요. 예: openssl rand -base64 32
# NODE_ENV=production에서 placeholder/짧은 값이면 서버가 시작하지 않습니다.
SESSION_SECRET=replace-with-a-strong-random-session-secret
SESSION_COOKIE_NAME=pdfm_session
SESSION_TTL_MS=2592000000
# 운영에서는 true 필수입니다. HTTPS/proxy 환경에서 secure cookie를 사용합니다.
COOKIE_SECURE=false
AUTH_STORE_PATH=./data/auth-store.json

# Polar.sh (WORK-02/WORK-03)
# Access token/webhook secret은 Polar dashboard에서 발급한 값을 사용하세요.
# checkout product ID는 서버 env에만 두고, 클라이언트 요청의 productId는 무시/거부됩니다.
POLAR_ACCESS_TOKEN=polar_oat_xxxxxxxxxxxxxxxxxxxxx
POLAR_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
POLAR_ONE_TIME_PRODUCT_ID=3c5002d7-b5aa-4c8d-8fe4-433e8d46c239
POLAR_MONTHLY_PRODUCT_ID=d7cd5993-4d33-46d9-8ba6-994c70b527f9
POLAR_CHECKOUT_CURRENCY=krw
POLAR_ONE_TIME_CHECKOUT_URL=https://buy.polar.sh/polar_cl_aGzorRvqZUgPJEt53EUCH6VZcuSyjV1hOrjBQ473ZZp
POLAR_MONTHLY_CHECKOUT_URL=https://buy.polar.sh/polar_cl_FFPmuDyi5Tp6g3NXSZWDenTjVJT2HYSN2UQu90uqaio
# POLAR_CHECKOUT_SUCCESS_URL=http://localhost:5173/pricing?success=true  # FRONTEND_URL + /pricing?success=true 자동 파생
# POLAR_CHECKOUT_CANCEL_URL=http://localhost:5173/pricing?canceled=true  # FRONTEND_URL + /pricing?canceled=true 자동 파생

# 관리자/운영 MVP (WORK-14)
# Google 로그인된 사용자 중 아래 email만 /api/admin/* 접근 허용
ADMIN_EMAILS=owner@example.com,ops@example.com
ADMIN_AUDIT_LOG_PATH=./data/admin-audit.log

# Runtime document-processing binaries (WORK-03/WORK-06)
HWPFORGE_PATH=../pdf-master-references/HwpForge/target/release/hwpforge
SOFFICE_PATH=soffice
HWPX2HTML_PATH=./server/hwpx2html.py
MD2HTML_PATH=./scripts/md2html.py
RHWP_PATH=rhwp
RHWP_INGEST_EXPORTER_PATH=rhwp-ingest-exporter
PDFTOTEXT_PATH=pdftotext
PDFTOHTML_PATH=pdftohtml
PDFTOPPM_PATH=pdftoppm
QPDF_PATH=qpdf
GHOSTSCRIPT_PATH=gs
